#!/usr/bin/env python
# vim: fileencoding=utf-8

from calibre.web.feeds.news import BasicNewsRecipe
from calibre.ebooks.BeautifulSoup import BeautifulSoup
import re
import urllib.request
import xml.etree.ElementTree as ET

class NatureNews(BasicNewsRecipe):
    """
    抓取 Nature 杂志的最新文章
    使用 RDF/RSS 1.0 解析
    """
    
    title = 'Nature News'
    language = 'en_GB'
    encoding = 'utf-8'
    __author__ = 'Calibre User'
    description = 'Latest news, research highlights and commentary from Nature'
    
    # 封面图片
    cover_url = 'https://www.nature.com/uploads/product/nature/rss.png'
    masthead_url = 'https://www.nature.com/uploads/product/nature/rss.png'
    
    # 不要使用默认的 feeds 解析
    # 我们手动获取和解析
    feeds = []
    
    # 文章设置
    oldest_article = 7
    max_articles_per_feed = 5
    delay = 1
    ignore_duplicate_articles = {'url', 'title'}
    
    # 自定义 CSS
    extra_css = '''
        body { 
            font-family: Georgia, "Times New Roman", serif; 
            font-size: 14px; 
            line-height: 1.6; 
            max-width: 800px; 
            margin: 0 auto; 
            padding: 20px;
            color: #222;
        }
        h1 { 
            font-size: 1.8em; 
            font-weight: bold; 
            margin-top: 0.5em; 
            margin-bottom: 0.5em;
            color: #000;
        }
        .article-title { font-size: 1.5em; font-weight: bold; color: #1a1a1a; }
        .article-meta { color: #666; font-size: 0.9em; margin-bottom: 1em; }
        .author { color: #444; font-size: 0.95em; font-style: italic; }
        .date { color: #888; font-size: 0.9em; }
        .summary { 
            font-style: italic; 
            color: #333; 
            background: #f5f5f5; 
            padding: 10px 15px; 
            border-left: 4px solid #8B0000;
            margin: 1em 0;
        }
        .doi { color: #999; font-size: 0.85em; font-family: monospace; }
        img { max-width: 100%; height: auto; display: block; margin: 1em auto; }
        p { margin: 0.8em 0; }
        .article-item {
            border-bottom: 1px solid #e0e0e0;
            padding: 1em 0;
        }
        .article-item:last-child { border-bottom: none; }
        a { color: #0055A4; text-decoration: none; }
        a:hover { text-decoration: underline; }
    '''
    
    def get_browser(self, *args, **kwargs):
        from calibre.utils.random_ua import random_common_chrome_user_agent
        kwargs['user_agent'] = kwargs.get('user_agent', random_common_chrome_user_agent())
        return BasicNewsRecipe.get_browser(self, *args, **kwargs)
    
    def parse_index(self):
        """
        手动解析 RDF/RSS 1.0 格式
        """
        rss_url = 'http://feeds.nature.com/nature/rss/current'
        self.log(f'Fetching RSS: {rss_url}')
        
        # 获取 RSS 内容
        try:
            response = urllib.request.urlopen(rss_url)
            rss_content = response.read().decode('utf-8')
        except Exception as e:
            self.log(f'Error fetching RSS: {e}')
            return []
        
        # 解析 XML
        try:
            root = ET.fromstring(rss_content)
        except Exception as e:
            self.log(f'Error parsing XML: {e}')
            return []
        
        # 定义命名空间
        ns = {
            'rdf': 'http://www.w3.org/1999/02/22-rdf-syntax-ns#',
            'dc': 'http://purl.org/dc/elements/1.1/',
            'content': 'http://purl.org/rss/1.0/modules/content/',
            'prism': 'http://prismstandard.org/namespaces/basic/2.0/',
            'rss': 'http://purl.org/rss/1.0/'
        }
        
        # 查找所有 item
        items = root.findall('.//rss:item', ns)
        self.log(f'Found {len(items)} items')
        
        articles = []
        seen_urls = set()
        
        for item in items:
            try:
                # 提取标题
                title_elem = item.find('dc:title', ns)
                title = title_elem.text if title_elem is not None else ''
                
                # 提取链接
                link_elem = item.find('rss:link', ns)
                url = link_elem.text if link_elem is not None else ''
                
                # 提取作者
                creator_elem = item.find('dc:creator', ns)
                author = creator_elem.text if creator_elem is not None else ''
                
                # 提取日期
                date_elem = item.find('dc:date', ns)
                date = date_elem.text if date_elem is not None else ''
                
                # 提取摘要
                content_elem = item.find('content:encoded', ns)
                summary = ''
                if content_elem is not None:
                    # 从 CDATA 中提取纯文本
                    content_text = content_elem.text or ''
                    # 去除 HTML 标签
                    summary = re.sub(r'<[^>]+>', '', content_text)
                    # 提取描述部分
                    if 'doi:' in summary:
                        parts = summary.split('doi:')
                        if len(parts) > 1:
                            summary = summary.split('doi:')[0].strip()
                
                # 提取 DOI
                doi_elem = item.find('prism:doi', ns)
                doi = doi_elem.text if doi_elem is not None else ''
                
                if not title or not url:
                    continue
                
                # 去重
                if url in seen_urls:
                    continue
                seen_urls.add(url)
                
                # 构建文章条目
                articles.append({
                    'title': title,
                    'url': url,
                    'description': summary,
                    'author': author,
                    'date': date,
                    'doi': doi
                })
                
            except Exception as e:
                self.log(f'Error parsing item: {e}')
                continue
        
        self.log(f'Successfully parsed {len(articles)} articles')
        
        # 按日期排序（最新的在前）
        articles.sort(key=lambda x: x.get('date', ''), reverse=True)
        
        # 返回 feeds 格式
        return [('Latest Articles', articles)]
    
    def preprocess_html(self, soup):
        """预处理文章 HTML"""
        
        # 处理图片
        for img in soup.find_all('img', src=True):
            if 'nature.com' in img['src'] and 'cdn-cgi' not in img['src']:
                img['src'] = img['src'].replace(
                    'nature.com/',
                    'nature.com/cdn-cgi/image/width=600,quality=80,format=auto/'
                )
        
        # 美化标题
        for h1 in soup.find_all('h1'):
            if h1.get_text().strip():
                h1['class'] = 'article-title'
        
        # 移除脚本和样式
        for tag in soup.find_all(['script', 'style', 'noscript']):
            tag.decompose()
        
        return soup
    
    def publication_date(self):
        from datetime import datetime
        from calibre.utils.date import local_tz
        return datetime.now().replace(tzinfo=local_tz)
