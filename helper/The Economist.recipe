#!/usr/bin/env python
# vim:fileencoding=utf-8

from calibre.web.feeds.news import BasicNewsRecipe
from calibre.ebooks.BeautifulSoup import BeautifulSoup
import re

class TheEconomist(BasicNewsRecipe):
    title = 'The Economist'
    __author__ = 'Kovid Goyal'
    description = 'Global news and current affairs from a European perspective.'
    language = 'en_GB'
    
    # 封面图片
    masthead_url = 'https://www.economist.com/sites/default/files/econfinal.jpg'
    
    # 需要登录吗？
    needs_subscription = False
    
    # 延迟设置，避免被屏蔽
    delay = 5
    
    # 额外CSS样式
    extra_css = '''
        .headline { font-size: 1.4em; font-weight: bold; }
        .byline { color: #666; font-style: italic; }
        .summary { font-size: 0.95em; color: #333; }
        .section { font-weight: bold; font-size: 1.1em; margin-top: 1em; }
        img { max-width: 100%; }
    '''
    
    # 忽略的URL模式（跳过交互式内容）
    ignore_article_url_patterns = [
        r'/interactive/',
        r'/podcast/',
        r'/video/',
    ]
    
    def parse_index(self):
        # 获取周刊主页
        index_url = 'https://www.economist.com/weeklyedition'
        soup = self.index_to_soup(index_url)
        
        articles = []
        
        # 查找文章列表 - 根据当前网页结构调整选择器
        for section in soup.find_all('section', class_='weekly-edition-section'):
            section_title = section.find('h2')
            if section_title:
                section_name = section_title.get_text(strip=True)
            else:
                section_name = 'Articles'
            
            section_articles = []
            for article in section.find_all('article'):
                link = article.find('a', href=True)
                if not link:
                    continue
                
                url = link.get('href')
                if not url.startswith('http'):
                    url = 'https://www.economist.com' + url
                
                title = link.get_text(strip=True)
                if not title:
                    continue
                
                # 尝试获取摘要
                summary = ''
                desc = article.find('p', class_='description')
                if desc:
                    summary = desc.get_text(strip=True)
                
                section_articles.append({
                    'title': title,
                    'url': url,
                    'description': summary,
                })
            
            if section_articles:
                articles.append((section_name, section_articles))
        
        return articles
    
    def preprocess_html(self, soup):
        # 清理不需要的元素
        for tag in soup.find_all(['script', 'style', 'noscript', 'iframe']):
            tag.decompose()
        
        # 移除广告
        for ad in soup.find_all(class_=re.compile(r'ad|advertisement|sponsor')):
            ad.decompose()
        
        # 处理文章标题
        for h1 in soup.find_all('h1'):
            h1['class'] = 'headline'
        
        # 处理作者信息
        for byline in soup.find_all(class_=re.compile(r'byline|author')):
            byline['class'] = 'byline'
        
        return soup
    
    def publication_date(self):
        # 返回当前日期或从页面获取
        from datetime import datetime
        
        # 尝试从weeklyedition页面获取日期
        try:
            soup = self.index_to_soup('https://www.economist.com/weeklyedition')
            date_elem = soup.find('time')
            if date_elem and date_elem.get('datetime'):
                date_str = date_elem.get('datetime')[:10]
                return datetime.strptime(date_str, '%Y-%m-%d')
        except:
            pass
        
        # 如果获取失败，返回当前日期
        return datetime.now()
