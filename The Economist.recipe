#!/usr/bin/env python
import json
import re
from datetime import datetime, timedelta
from calibre.ptempfile import PersistentTemporaryFile
from calibre.utils.date import local_tz
from calibre.web.feeds.news import BasicNewsRecipe
from html5_parser import parse
from lxml import etree


def process_url(url):
    if url.startswith('/'):
        return 'https://www.economist.com' + url
    return url


def extract_cover_url(content):
    """提取封面图片URL"""
    cover = content.get('cover', {})
    url = cover.get('url', '')
    if url:
        return url.replace(
            'economist.com/',
            'economist.com/cdn-cgi/image/width=960,quality=80,format=auto/'
        )
    return ''


def extract_articles_from_components(components):
    """从components中提取所有文章，按栏目分组"""
    feeds = []
    seen = set()
    
    for component in components:
        # 跳过广告
        if component.get('type') == 'AD':
            continue
        
        # 只处理栏目集合
        if component.get('type') != 'COLLECTION':
            continue
        
        section_name = component.get('name', '未命名栏目')
        articles = []
        
        for article in component.get('articles', []):
            article_id = article.get('id')
            url = process_url(article.get('url', ''))
            headline = article.get('headline', '')
            
            # 去重
            if article_id in seen or not url or not headline:
                continue
            seen.add(article_id)
            
            articles.append({
                'title': headline,
                'url': url,
                'description': article.get('rubric', '')
            })
        
        if articles:
            feeds.append((section_name, articles))
    
    return feeds


class Economist(BasicNewsRecipe):
    title = 'The Economist'
    language = 'en_GB'
    encoding = 'utf-8'
    __author__ = 'Calibre Community'
    description = 'Weekly edition of The Economist'
    extra_css = '''
        img { max-width: 100%; height: auto; display: block; margin: 0 auto; }
        h1 { font-size: 1.8em; }
        h4 { font-size: 1.2em; margin-top: 1em; }
        blockquote { margin: 1em 2em; color: #404040; }
        .article-meta { color: gray; font-size: small; }
    '''
    delay = 2
    browser_type = 'webengine'
    ignore_duplicate_articles = {'url'}
    
    recipe_specific_options = {
        'date': {
            'short': 'Edition date (YYYY-MM-DD)',
            'default': '',
        },
        'res': {
            'short': 'Image width in pixels',
            'default': '600',
        },
    }

    def get_browser(self, *args, **kwargs):
        from calibre.utils.random_ua import random_common_chrome_user_agent
        kwargs['user_agent'] = kwargs.get('user_agent', random_common_chrome_user_agent())
        return BasicNewsRecipe.get_browser(self, *args, **kwargs)

    def publication_date(self):
        date_str = self.recipe_specific_options.get('date', '').strip()
        if date_str:
            try:
                return datetime.strptime(date_str, '%Y-%m-%d').replace(tzinfo=local_tz)
            except:
                pass
        return datetime.now().replace(tzinfo=local_tz)

    def parse_index(self):
        date_str = self.recipe_specific_options.get('date', '').strip()
        if date_str:
            url = f'https://www.economist.com/weeklyedition/{date_str}'
        else:
            url = 'https://www.economist.com/weeklyedition'
            # 如果没有指定日期，访问首页会重定向到最新一期
            try:
                resp = self.browser.open(url)
                url = resp.geturl()
                # 从URL中提取日期
                match = re.search(r'/(\d{4}-\d{2}-\d{2})$', url)
                if match:
                    date_str = match.group(1)
            except:
                pass

        self.log(f'Fetching: {url}')
        soup = self.index_to_soup(url)
        
        # 获取 __NEXT_DATA__ 脚本
        script_tag = soup.find('script', id='__NEXT_DATA__')
        if not script_tag:
            raise Exception('No __NEXT_DATA__ found')

        data = json.loads(script_tag.string)
        content = data.get('props', {}).get('pageProps', {}).get('content', {})
        
        if not content:
            raise Exception('No content data found')

        # 设置封面
        cover_url = extract_cover_url(content)
        if cover_url:
            self.cover_url = cover_url
            self.log(f'Cover: {cover_url}')

        # 设置描述
        self.description = content.get('headline', 'The Economist')

        # 设置时间格式
        issue_date = content.get('issueDate', '')
        if issue_date:
            self.timefmt = f' [{issue_date[:10]}]'

        # 提取文章
        components = content.get('components', [])
        feeds = extract_articles_from_components(components)
        
        if not feeds:
            raise Exception('No articles found')

        total = sum(len(articles) for _, articles in feeds)
        self.log(f'Found {total} articles in {len(feeds)} sections')
        
        return feeds

    def preprocess_html(self, soup):
        width = self.recipe_specific_options.get('res', '600')
        for img in soup.find_all('img', src=True):
            if 'economist.com' in img['src'] and 'cdn-cgi' not in img['src']:
                img['src'] = img['src'].replace(
                    'economist.com/',
                    f'economist.com/cdn-cgi/image/width={width},quality=80,format=auto/'
                )
        return soup

    def print_version(self, url):
        """直接返回文章URL，让Calibre处理"""
        return url
